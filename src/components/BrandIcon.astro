---
type BrandIconData = {
  title: string;
  path: string;
  hex: string;
};

interface Props {
  icon: BrandIconData;
  size?: number;
  label?: string;
  monochrome?: boolean;
}

const { icon, size = 24, label, monochrome = false } = Astro.props;
const accessibleLabel = label ?? icon.title;
---

<svg
  class="brand-icon"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="currentColor"
  style={monochrome ? undefined : `color:#${icon.hex}`}
  role={label ? 'img' : undefined}
  aria-label={label ? accessibleLabel : undefined}
  aria-hidden={label ? undefined : 'true'}
  focusable="false"
>
  <path d={icon.path}></path>
</svg>
