---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import { PortfolioApp } from '../lib/components/portfolio/PortfolioApp';
import { getFeaturedRepositories } from '../lib/infrastructure/github/getFeaturedRepositories';
import {
  useCertifications,
  useEducation,
  useExperiences,
  useLanguages,
  usePersonalInfo,
  useSkills,
  useSoftSkills,
} from '../lib/presentation/hooks/usePortfolio';

const [
  personalInfo,
  experiences,
  education,
  certifications,
  skills,
  softSkills,
  languages,
  repositories,
] = await Promise.all([
  usePersonalInfo(),
  useExperiences(),
  useEducation(),
  useCertifications(),
  useSkills(),
  useSoftSkills(),
  useLanguages(),
  getFeaturedRepositories(),
]);
---

<Layout>
  <PortfolioApp
    client:idle
    personalInfo={personalInfo}
    experiences={experiences}
    education={education}
    certifications={certifications}
    skills={skills}
    softSkills={softSkills}
    languages={languages}
    repositories={repositories}
  />
</Layout>

<style is:global>
  .divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgb(var(--color-primary-200)),
      transparent
    );
    margin: 0 auto;
    max-width: 80%;
  }

  @media (min-width: 1280px) {
    .divider {
      max-width: 60%;
    }
  }
</style>
