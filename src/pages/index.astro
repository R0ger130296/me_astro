---
import '../styles/global.css';
import '../styles/nav-fix.css';
import BrandIcon from '../components/BrandIcon.astro';
import { siAstro, siDocker, siDotnet, siExpo, siFirebase, siGit, siGraphql, siMicrosoftazure, siMicrosoftsqlserver, siNodedotjs, siReact, siTailwindcss, siTypescript } from 'simple-icons';
import {
  ArrowRight,
  Award,
  BadgeCheck,
  BriefcaseBusiness,
  CalendarDays,
  Clock3,
  Code2,
  Github,
  Linkedin,
  Mail,
  MapPin,
  MessageCircle,
  Rocket,
  Send,
  Star,
  UserRound,
} from '@lucide/astro';

type Repo = {
  name: string;
  html_url: string;
  homepage: string | null;
  description: string | null;
  language: string | null;
  stargazers_count: number;
  forks_count: number;
  updated_at: string;
};

const fallbackRepos: Repo[] = [
  {
    name: 'financiaApp',
    html_url: 'https://github.com/R0ger130296/financiaApp',
    homepage: null,
    description: 'Aplicación web para gestión de finanzas personales.',
    language: 'TypeScript',
    stargazers_count: 0,
    forks_count: 0,
    updated_at: new Date().toISOString(),
  },
  {
    name: 'me_astro',
    html_url: 'https://github.com/R0ger130296/me_astro',
    homepage: 'https://rogercedeno.dev',
    description: 'Portafolio profesional desarrollado con Astro y TypeScript.',
    language: 'Astro',
    stargazers_count: 0,
    forks_count: 0,
    updated_at: new Date().toISOString(),
  },
];

let githubRepos = fallbackRepos;
try {
  const response = await fetch('https://api.github.com/users/R0ger130296/repos?per_page=100&sort=updated', {
    headers: {
      Accept: 'application/vnd.github+json',
      'User-Agent': 'roger-cedeno-portfolio',
      ...(import.meta.env.GITHUB_TOKEN ? { Authorization: `Bearer ${import.meta.env.GITHUB_TOKEN}` } : {}),
    },
    signal: AbortSignal.timeout(3500),
  });
  if (response.ok) githubRepos = await response.json();
} catch {
  githubRepos = fallbackRepos;
}

const repoByName = new Map(githubRepos.map((repo) => [repo.name.toLowerCase(), repo]));
const formatDate = (value: string) =>
  new Intl.DateTimeFormat('es-EC', { month: 'short', year: 'numeric' }).format(new Date(value));

const projects = [
  {
    title: 'FinanciaApp',
    icon: siReact,
    status: 'En producción',
    tone: 'green',
    description: 'Aplicación web para gestionar ingresos, gastos, cuentas y presupuestos personales.',
    tags: ['React', 'TypeScript', 'PWA'],
    repo: repoByName.get('financiaapp'),
  },
  {
    title: 'Auriga',
    icon: siDotnet,
    status: 'En desarrollo',
    tone: 'blue',
    description: 'Plataforma empresarial para talleres automotrices, órdenes de trabajo, citas y técnicos.',
    tags: ['React', '.NET 8', 'SQL Server', 'Azure'],
    repo: null,
  },
  {
    title: 'App Colaboradores',
    icon: siExpo,
    status: 'En producción',
    tone: 'green',
    description: 'Aplicación móvil interna para colaboradores, notificaciones y gestión de tareas.',
    tags: ['React Native', 'Expo', 'Firebase'],
    repo: null,
  },
  {
    title: 'Apollo GraphQL',
    icon: siGraphql,
    status: 'Proyecto técnico',
    tone: 'purple',
    description: 'Servidor GraphQL escalable con autenticación, roles, documentación y contenedores.',
    tags: ['Node.js', 'GraphQL', 'MongoDB', 'Docker'],
    repo: null,
  },
  {
    title: 'Portafolio v4',
    icon: siAstro,
    status: 'En producción',
    tone: 'green',
    description: 'Portafolio profesional optimizado para rendimiento, SEO e integración con GitHub.',
    tags: ['Astro', 'TypeScript', 'Vercel'],
    repo: repoByName.get('me_astro'),
  },
];

const technologies = [
  { name: 'React', icon: siReact },
  { name: 'TypeScript', icon: siTypescript },
  { name: '.NET', icon: siDotnet },
  { name: 'Node.js', icon: siNodedotjs },
  { name: 'Astro', icon: siAstro },
  { name: 'Azure', icon: siMicrosoftazure },
  { name: 'SQL Server', icon: siMicrosoftsqlserver },
  { name: 'Firebase', icon: siFirebase },
  { name: 'Docker', icon: siDocker },
  { name: 'Git', icon: siGit },
  { name: 'Tailwind CSS', icon: siTailwindcss },
  { name: 'GraphQL', icon: siGraphql },
];

const year = new Date().getFullYear();
const canonical = 'https://rogercedeno.dev/';
const title = 'Roger Cedeño | Full Stack Developer';
const description =
  'Portafolio profesional de Roger Cedeño, desarrollador Full Stack especializado en React, TypeScript, .NET, aplicaciones móviles y soluciones cloud.';
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Roger Cedeño',
  jobTitle: 'Full Stack Developer',
  url: canonical,
  image: `${canonical}me/1757515565808.jpeg`,
  address: { '@type': 'PostalAddress', addressCountry: 'EC' },
  sameAs: ['https://github.com/R0ger130296'],
};
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="author" content="Roger Cedeño" />
    <meta name="theme-color" content="#050714" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${canonical}me/1757515565808.jpeg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${canonical}me/1757515565808.jpeg`} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>

    <header class="site-header">
      <nav class="shell nav" aria-label="Navegación principal">
        <a class="brand" href="#inicio">
          <span class="brand-mark">RC</span>
          <span><strong>Roger Cedeño</strong><small>Full Stack Developer</small></span>
        </a>
        <div class="nav-links">
          <a class="active" href="#inicio">Inicio</a>
          <a href="#sobre-mi">Sobre mí</a>
          <a href="#experiencia">Experiencia</a>
          <a href="#proyectos">Proyectos</a>
          <a href="#habilidades">Habilidades</a>
          <a href="#contacto">Contacto</a>
        </div>
        <a class="cv-button" href="mailto:rogercedeno96@gmail.com"><Mail size={16} aria-hidden="true" />Contactar</a>
      </nav>
    </header>

    <main id="contenido">
      <section id="inicio" class="hero shell">
        <div class="hero-copy">
          <div class="availability"><span></span>Disponible para nuevos proyectos</div>
          <h1>Construyo soluciones digitales que generan <em>impacto real.</em></h1>
          <p>Desarrollador Full Stack especializado en construir aplicaciones web y móviles escalables, centradas en la experiencia de usuario y el negocio.</p>

          <div class="tech-pills" aria-label="Tecnologías principales">
            <span><BrandIcon icon={siReact} size={16} />React</span>
            <span><BrandIcon icon={siDotnet} size={16} />.NET</span>
            <span><BrandIcon icon={siTypescript} size={16} />TypeScript</span>
            <span><BrandIcon icon={siMicrosoftazure} size={16} />Azure</span>
            <span><BrandIcon icon={siAstro} size={16} />Astro</span>
          </div>

          <div class="hero-actions">
            <a class="button primary" href="#proyectos">Ver proyectos <ArrowRight size={18} aria-hidden="true" /></a>
            <a class="button secondary" href="#contacto">Contactarme</a>
            <a class="icon-button" href="https://github.com/R0ger130296" target="_blank" rel="noreferrer" aria-label="Ver perfil de GitHub"><Github size={21} aria-hidden="true" /></a>
          </div>
        </div>

        <div class="portrait-area">
          <div class="portrait-aura" aria-hidden="true"></div>
          <div class="portrait-card">
            <img src="/me/1757515565808.jpeg" alt="Retrato profesional de Roger Cedeño" width="800" height="1000" loading="eager" decoding="async" fetchpriority="high" />
            <div class="profile-overlay">
              <div><strong>Roger Cedeño</strong><span>Full Stack Developer</span></div>
              <span class="verified" aria-label="Perfil verificado"><BadgeCheck size={14} aria-hidden="true" /></span>
              <div class="profile-meta">
                <span><MapPin size={15} aria-hidden="true" />Ecuador</span>
                <span><Clock3 size={15} aria-hidden="true" />GMT -5</span>
                <span><BriefcaseBusiness size={15} aria-hidden="true" />6+ años de experiencia</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="metrics shell" aria-label="Resumen profesional">
        <article><span><CalendarDays size={21} aria-hidden="true" /></span><strong>6+</strong><small>Años de experiencia</small></article>
        <article><span><Rocket size={21} aria-hidden="true" /></span><strong>20+</strong><small>Proyectos completados</small></article>
        <article><span><Code2 size={21} aria-hidden="true" /></span><strong>{new Set(githubRepos.map((repo) => repo.language).filter(Boolean)).size || 10}+</strong><small>Tecnologías dominadas</small></article>
        <article><span><Award size={21} aria-hidden="true" /></span><strong>10+</strong><small>Certificaciones</small></article>
      </section>

      <section id="proyectos" class="section shell">
        <div class="section-title-row">
          <div><span class="kicker">Portafolio</span><h2>Proyectos destacados</h2></div>
          <a href="https://github.com/R0ger130296?tab=repositories" target="_blank" rel="noreferrer">Ver todos los proyectos <ArrowRight size={16} aria-hidden="true" /></a>
        </div>
        <div class="project-grid">
          {projects.map((project) => (
              <article class="project-card">
                <div class="project-top"><span class="project-icon"><BrandIcon icon={project.icon} size={22} label={project.title} /></span><span class={`status ${project.tone}`}>{project.status}</span></div>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <div class="tags">{project.tags.map((tag) => <span>{tag}</span>)}</div>
                <div class="project-footer">
                  {project.repo ? <small>Actualizado {formatDate(project.repo.updated_at)}</small> : <small>Proyecto privado</small>}
                  {project.repo ? <a href={project.repo.html_url} target="_blank" rel="noreferrer">Ver código <ArrowRight size={14} aria-hidden="true" /></a> : <a href="#contacto">Ver detalles <ArrowRight size={14} aria-hidden="true" /></a>}
                </div>
              </article>
          ))}
        </div>
      </section>

      <section id="sobre-mi" class="content-grid shell section">
        <article class="panel about-panel">
          <header><UserRound size={20} aria-hidden="true" /><h2>Sobre mí</h2></header>
          <p>Soy desarrollador Full Stack con más de 6 años de experiencia diseñando y construyendo aplicaciones escalables, seguras y centradas en el usuario.</p>
          <p>Me especializo en React, .NET, Azure y arquitecturas cloud-first. Disfruto transformar ideas en productos digitales que mejoran procesos reales.</p>
          <a class="mail-link" href="mailto:rogercedeno96@gmail.com"><Mail size={17} aria-hidden="true" />rogercedeno96@gmail.com</a>
          <div class="socials">
            <a href="https://github.com/R0ger130296" target="_blank" rel="noreferrer" aria-label="GitHub"><Github size={19} aria-hidden="true" /></a>
            <a href="#contacto" aria-label="LinkedIn"><Linkedin size={19} aria-hidden="true" /></a>
            <a href="#contacto" aria-label="WhatsApp"><MessageCircle size={19} aria-hidden="true" /></a>
          </div>
        </article>

        <article id="habilidades" class="panel skills-panel">
          <header><Code2 size={20} aria-hidden="true" /><h2>Tecnologías principales</h2></header>
          <div class="technology-grid">
            {technologies.map(({ name, icon }) => (
              <div><BrandIcon icon={icon} size={24} label={name} /><span>{name}</span></div>
            ))}
          </div>
          <a class="panel-link" href="https://github.com/R0ger130296" target="_blank" rel="noreferrer">Ver actividad técnica <ArrowRight size={15} aria-hidden="true" /></a>
        </article>

        <article class="panel strengths-panel">
          <header><Star size={20} aria-hidden="true" /><h2>Fortalezas</h2></header>
          <ul>
            <li>Código limpio y mantenible</li>
            <li>Pensamiento analítico</li>
            <li>Resolución de problemas</li>
            <li>Trabajo en equipo</li>
            <li>Aprendizaje continuo</li>
            <li>Orientación a resultados</li>
          </ul>
          <div class="cta-card"><strong>¿Tienes un proyecto en mente?</strong><p>Hablemos sobre cómo puedo ayudarte a hacerlo realidad.</p><a href="mailto:rogercedeno96@gmail.com">Contactarme <ArrowRight size={15} aria-hidden="true" /></a></div>
        </article>
      </section>

      <section id="experiencia" class="section shell experience-section">
        <div><span class="kicker">Experiencia</span><h2>Soluciones para operaciones reales</h2></div>
        <div class="experience-list">
          <article><span>01</span><div><h3>Desarrollo full stack</h3><p>React, TypeScript, .NET 8, SQL Server y reglas de negocio empresariales.</p></div></article>
          <article><span>02</span><div><h3>Aplicaciones móviles y PWA</h3><p>React Native, Flutter, Cordova y acceso a capacidades del dispositivo.</p></div></article>
          <article><span>03</span><div><h3>Cloud y DevOps</h3><p>Azure, Docker, GitHub Actions, Vercel y despliegues reproducibles.</p></div></article>
        </div>
      </section>

      <section id="contacto" class="contact shell">
        <div><span class="kicker">Contacto</span><h2>¿Construimos algo juntos?</h2><p>Disponible para oportunidades, colaboración técnica y desarrollo de productos digitales.</p></div>
        <a class="button primary" href="mailto:rogercedeno96@gmail.com"><Send size={18} aria-hidden="true" />Enviar correo</a>
      </section>
    </main>

    <footer class="footer shell"><div class="brand"><span class="brand-mark">RC</span><span><strong>Roger Cedeño</strong><small>Full Stack Developer</small></span></div><span>© {year} Roger Cedeño. Todos los derechos reservados.</span><nav><a href="#inicio">Inicio</a><a href="#proyectos">Proyectos</a><a href="#contacto">Contacto</a></nav></footer>

    <script is:inline>
      if ('serviceWorker' in navigator) window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js').catch(() => {}));
    </script>
  </body>
</html>
