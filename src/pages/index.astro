---
import '../styles/global.css';
import * as Lucide from '@lucide/astro';
import { capabilities, principles, profile, projects, technologies } from '../data/portfolio';
import { getGitHubRepos, getRepositoryMap } from '../services/github';

const {
  ArrowRight, ArrowUpRight, BadgeCheck, BarChart3, BriefcaseBusiness, Check,
  ChevronDown, Code2, Github, Layers3, Mail, MapPin, Menu, MessageCircle,
  MoonStar, Rocket, Send, Sparkles, Star, X,
} = Lucide;

const repositories = await getGitHubRepos();
const repositoryMap = getRepositoryMap(repositories);
const languages = new Set(repositories.map((repo) => repo.language).filter(Boolean));
const totalStars = repositories.reduce((total, repo) => total + repo.stargazers_count, 0);
const formatDate = (value: string) => new Intl.DateTimeFormat('es-EC', { month: 'short', year: 'numeric' }).format(new Date(value));
const year = new Date().getFullYear();
const canonical = 'https://rogercedeno.dev/';
const title = 'Roger Cedeño | Full Stack Developer & Product Builder';
const description = 'Portafolio de Roger Cedeño, desarrollador Full Stack especializado en productos web, móviles, cloud y experiencias digitales centradas en negocio.';
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  jobTitle: profile.role,
  url: canonical,
  image: `${canonical}me/1757515565808.jpeg`,
  email: `mailto:${profile.email}`,
  address: { '@type': 'PostalAddress', addressCountry: 'EC' },
  sameAs: [profile.github],
  knowsAbout: technologies,
};
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="author" content={profile.name} />
    <meta name="theme-color" content="#07090f" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${canonical}me/1757515565808.jpeg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${canonical}me/1757515565808.jpeg`} />
    <title>{title}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <div class="ambient ambient-one" aria-hidden="true"></div>
    <div class="ambient ambient-two" aria-hidden="true"></div>

    <header class="site-header" data-header>
      <nav class="shell nav" aria-label="Navegación principal">
        <a class="brand" href="#inicio" aria-label="Ir al inicio">
          <span class="brand-mark">RC</span>
          <span><strong>Roger Cedeño</strong><small>Full Stack · Product Builder</small></span>
        </a>
        <div class="nav-links" data-nav-links>
          <a href="#proyectos">Trabajo</a><a href="#servicios">Capacidades</a><a href="#sobre-mi">Perfil</a><a href="#contacto">Contacto</a>
        </div>
        <div class="nav-actions">
          <a class="nav-cta" href={`mailto:${profile.email}`}><Mail size={16} />Hablemos</a>
          <button class="menu-button" type="button" aria-label="Abrir menú" aria-expanded="false" data-menu-button><Menu size={21} /><X size={21} /></button>
        </div>
      </nav>
    </header>

    <main id="contenido">
      <section id="inicio" class="hero shell">
        <div class="hero-copy reveal">
          <div class="eyebrow"><span></span>Disponible para proyectos seleccionados</div>
          <p class="overline">Desarrollo · Diseño de producto · Arquitectura</p>
          <h1>Convierto ideas complejas en <em>productos digitales claros.</em></h1>
          <p class="hero-summary">{profile.summary}</p>
          <div class="hero-actions">
            <a class="button primary" href="#proyectos">Explorar trabajo <ArrowRight size={18} /></a>
            <a class="button secondary" href={`mailto:${profile.email}`}>Iniciar conversación</a>
            <a class="icon-button" href={profile.github} target="_blank" rel="noreferrer" aria-label="GitHub"><Github size={20} /></a>
          </div>
          <div class="trust-line"><span><BadgeCheck size={17} />6+ años construyendo software</span><span><MapPin size={17} />{profile.location}</span></div>
        </div>

        <div class="hero-visual reveal">
          <div class="portrait-shell">
            <div class="portrait-grid" aria-hidden="true"></div>
            <img src="/me/1757515565808.jpeg" alt="Retrato profesional de Roger Cedeño" width="800" height="1000" loading="eager" decoding="async" fetchpriority="high" />
            <div class="portrait-caption"><div><strong>{profile.name}</strong><span>{profile.role}</span></div><BadgeCheck size={20} /></div>
          </div>
          <div class="floating-card code-card"><Code2 size={18} /><span><small>Stack principal</small><strong>React · .NET · TypeScript</strong></span></div>
          <div class="floating-card delivery-card"><Rocket size={18} /><span><small>Enfoque</small><strong>Producto + ejecución</strong></span></div>
        </div>
      </section>

      <section class="signal-strip shell" aria-label="Indicadores profesionales">
        <article><strong>6+</strong><span>Años de experiencia</span></article>
        <article><strong>20+</strong><span>Productos y proyectos</span></article>
        <article><strong>{languages.size || 10}+</strong><span>Tecnologías activas</span></article>
        <article><strong>{totalStars}</strong><span>Estrellas públicas</span></article>
      </section>

      <section id="proyectos" class="section shell">
        <div class="section-heading reveal"><div><span class="kicker">Trabajo seleccionado</span><h2>Casos que combinan negocio, UX y tecnología.</h2></div><p>No muestro código por mostrar. Cada proyecto explica el problema, la solución y el valor que puede generar.</p></div>
        <div class="project-grid">
          {projects.map((project, index) => {
            const repository = project.repository ? repositoryMap.get(project.repository.toLowerCase()) : undefined;
            return (
              <article class:list={['project-card', project.featured && 'featured', 'reveal']}>
                <div class="project-number">0{index + 1}</div>
                <div class="project-meta"><span class={`status status-${project.status.toLowerCase().replaceAll(' ', '-')}`}>{project.status}</span><span>{repository ? `Actualizado ${formatDate(repository.updated_at)}` : 'Trabajo privado'}</span></div>
                <h3>{project.title}</h3><p>{project.description}</p>
                <div class="impact"><Sparkles size={17} /><span>{project.impact}</span></div>
                <div class="tags">{project.tags.map((tag) => <span>{tag}</span>)}</div>
                <a href={project.href ?? '#contacto'} target={project.href ? '_blank' : undefined} rel={project.href ? 'noreferrer' : undefined}>Ver proyecto <ArrowUpRight size={16} /></a>
              </article>
            );
          })}
        </div>
      </section>

      <section id="servicios" class="section section-contrast">
        <div class="shell">
          <div class="section-heading reveal"><div><span class="kicker">Capacidades</span><h2>De la idea al producto operando.</h2></div><p>Puedo integrarme en una etapa puntual o acompañar el ciclo completo: descubrimiento, diseño técnico, implementación y entrega.</p></div>
          <div class="capability-grid">
            {capabilities.map((item, index) => <article class="capability-card reveal"><span>0{index + 1}</span><h3>{item.title}</h3><p>{item.description}</p><ArrowRight size={18} /></article>)}
          </div>
        </div>
      </section>

      <section id="sobre-mi" class="section shell about-layout">
        <div class="about-intro reveal"><span class="kicker">Cómo trabajo</span><h2>Ingeniería con criterio de producto.</h2><p>No separo “lo técnico” de “la experiencia”. Una buena solución debe ser usable, mantenible, rápida y útil para el negocio al mismo tiempo.</p><a class="text-link" href={profile.github} target="_blank" rel="noreferrer">Ver actividad en GitHub <ArrowUpRight size={16} /></a></div>
        <div class="principles reveal">
          {principles.map((principle) => <div><span><Check size={17} /></span><p>{principle}</p></div>)}
        </div>
        <aside class="profile-card reveal">
          <div class="profile-card-top"><MoonStar size={22} /><span>Perfil profesional</span></div>
          <h3>Full Stack con visión transversal</h3>
          <p>Experiencia en frontend, backend, mobile, bases de datos, cloud y automatización de entrega.</p>
          <div class="mini-stack">{technologies.map((technology) => <span>{technology}</span>)}</div>
        </aside>
      </section>

      <section class="section shell process-section">
        <div class="section-heading reveal"><div><span class="kicker">Proceso</span><h2>Menos ceremonia. Más claridad.</h2></div></div>
        <div class="process-grid">
          <article class="reveal"><Layers3 size={22} /><span>01</span><h3>Entender</h3><p>Objetivos, usuarios, restricciones, riesgos y definición de éxito.</p></article>
          <article class="reveal"><Star size={22} /><span>02</span><h3>Diseñar</h3><p>Flujos, arquitectura, contratos, estados y una experiencia coherente.</p></article>
          <article class="reveal"><Code2 size={22} /><span>03</span><h3>Construir</h3><p>Componentes mantenibles, datos tipados, pruebas y entregas pequeñas.</p></article>
          <article class="reveal"><BarChart3 size={22} /><span>04</span><h3>Mejorar</h3><p>Medición, observación, feedback y evolución continua del producto.</p></article>
        </div>
      </section>

      <section id="contacto" class="contact shell reveal">
        <div><span class="kicker">¿Tienes un reto?</span><h2>Construyamos algo que valga la pena usar.</h2><p>Cuéntame el contexto, el problema y qué resultado estás buscando.</p></div>
        <div class="contact-actions"><a class="button primary" href={`mailto:${profile.email}`}><Send size={18} />Enviar correo</a><a class="button secondary" href={profile.github} target="_blank" rel="noreferrer"><Github size={18} />GitHub</a></div>
      </section>
    </main>

    <footer class="footer shell"><div class="brand"><span class="brand-mark">RC</span><span><strong>{profile.name}</strong><small>{profile.role}</small></span></div><p>© {year} · Diseñado y construido con intención.</p><nav><a href="#inicio">Inicio</a><a href="#proyectos">Trabajo</a><a href="#contacto">Contacto</a></nav></footer>

    <script is:inline>
      const menuButton = document.querySelector('[data-menu-button]');
      const navigation = document.querySelector('[data-nav-links]');
      menuButton?.addEventListener('click', () => {
        const open = menuButton.getAttribute('aria-expanded') === 'true';
        menuButton.setAttribute('aria-expanded', String(!open));
        navigation?.classList.toggle('open', !open);
      });
      navigation?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => {
        menuButton?.setAttribute('aria-expanded', 'false'); navigation.classList.remove('open');
      }));
      const observer = new IntersectionObserver((entries) => entries.forEach((entry) => {
        if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); }
      }), { threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach((element) => observer.observe(element));
      if ('serviceWorker' in navigator) window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js').catch(() => {}));
    </script>
  </body>
</html>
