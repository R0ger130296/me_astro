---
import '../styles/global.css';

interface GitHubRepository {
  name: string;
  html_url: string;
  homepage: string | null;
  description: string | null;
  language: string | null;
  stargazers_count: number;
  forks_count: number;
  updated_at: string;
  fork: boolean;
  archived: boolean;
  topics?: string[];
}

interface PortfolioProject {
  name: string;
  title: string;
  description: string;
  url: string;
  demoUrl?: string;
  language: string;
  stars: number;
  forks: number;
  updatedAt: string;
  tags: string[];
  source: 'github' | 'local';
}

const githubUser = 'R0ger130296';
const priorityRepositories = ['me_astro', 'financiaApp'];
const technologies = ['React', 'TypeScript', '.NET 8', 'Astro', 'Azure', 'Docker'];
const now = new Date().toISOString();

const fallbackProjects: PortfolioProject[] = [
  {
    name: 'auriga-multibrand',
    title: 'Auriga Multibrand',
    description: 'Plataforma empresarial para órdenes de trabajo, recepción, técnicos, control de calidad y presupuestos.',
    url: `https://github.com/${githubUser}`,
    language: 'TypeScript / C#',
    stars: 0,
    forks: 0,
    updatedAt: now,
    tags: ['React', 'TypeScript', '.NET 8', 'SQL Server'],
    source: 'local',
  },
  {
    name: 'financiaApp',
    title: 'FinanciaApp',
    description: 'Aplicación mobile-first para administrar ingresos, gastos, cuentas y reportes financieros personales.',
    url: `https://github.com/${githubUser}/financiaApp`,
    language: 'TypeScript',
    stars: 0,
    forks: 0,
    updatedAt: now,
    tags: ['React', 'PWA', 'UX/UI', 'APIs'],
    source: 'local',
  },
  {
    name: 'me_astro',
    title: 'Portafolio profesional',
    description: 'Experiencia web estática, rápida y accesible para presentar experiencia, habilidades y proyectos.',
    url: `https://github.com/${githubUser}/me_astro`,
    language: 'Astro',
    stars: 0,
    forks: 0,
    updatedAt: now,
    tags: ['Astro', 'TypeScript', 'SEO', 'Vercel'],
    source: 'local',
  },
];

const titleFromRepository = (name: string) =>
  name.replace(/[-_]+/g, ' ').replace(/\b\w/g, (letter) => letter.toUpperCase());

const relativeDate = (value: string) => {
  const days = Math.max(0, Math.floor((Date.now() - new Date(value).getTime()) / 86_400_000));
  if (days === 0) return 'Actualizado hoy';
  if (days === 1) return 'Actualizado ayer';
  if (days < 30) return `Actualizado hace ${days} días`;
  const months = Math.floor(days / 30);
  if (months === 1) return 'Actualizado hace 1 mes';
  if (months < 12) return `Actualizado hace ${months} meses`;
  const years = Math.floor(months / 12);
  return `Actualizado hace ${years} ${years === 1 ? 'año' : 'años'}`;
};

let githubProjects: PortfolioProject[] = [];
let repositoryCount = fallbackProjects.length;
let githubAvailable = false;

try {
  const token = import.meta.env.GITHUB_TOKEN;
  const response = await fetch(`https://api.github.com/users/${githubUser}/repos?type=owner&sort=updated&per_page=100`, {
    headers: {
      Accept: 'application/vnd.github+json',
      'X-GitHub-Api-Version': '2022-11-28',
      ...(token ? { Authorization: `Bearer ${token}` } : {}),
    },
  });

  if (response.ok) {
    const repositories = (await response.json()) as GitHubRepository[];
    const eligible = repositories.filter((repository) => !repository.fork && !repository.archived);
    repositoryCount = eligible.length;
    githubProjects = eligible
      .sort((a, b) => {
        const aPriority = priorityRepositories.indexOf(a.name);
        const bPriority = priorityRepositories.indexOf(b.name);
        if (aPriority !== -1 || bPriority !== -1) {
          if (aPriority === -1) return 1;
          if (bPriority === -1) return -1;
          return aPriority - bPriority;
        }
        return new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime();
      })
      .slice(0, 6)
      .map((repository) => ({
        name: repository.name,
        title: titleFromRepository(repository.name),
        description: repository.description ?? 'Proyecto de software desarrollado con foco en calidad, mantenibilidad y experiencia de usuario.',
        url: repository.html_url,
        demoUrl: repository.homepage || undefined,
        language: repository.language ?? 'Software',
        stars: repository.stargazers_count,
        forks: repository.forks_count,
        updatedAt: repository.updated_at,
        tags: [repository.language, ...(repository.topics ?? [])].filter((tag): tag is string => Boolean(tag)).slice(0, 4),
        source: 'github' as const,
      }));
    githubAvailable = githubProjects.length > 0;
  }
} catch {
  githubAvailable = false;
}

const projects = githubAvailable ? githubProjects : fallbackProjects;
const activeProjects = projects.slice(0, 3);
const languages = Array.from(new Set(projects.map((project) => project.language))).filter(Boolean);
const year = new Date().getFullYear();
const canonical = 'https://rogercedeno.dev/';
const title = 'Roger Cedeño | Full Stack Software Developer';
const description = 'Portafolio profesional de Roger Cedeño, desarrollador full stack especializado en React, TypeScript, .NET, APIs, aplicaciones móviles y soluciones cloud.';
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Roger Cedeño',
  jobTitle: 'Full Stack Software Developer',
  url: canonical,
  image: `${canonical}me/1757515565808.jpeg`,
  address: { '@type': 'PostalAddress', addressCountry: 'EC' },
  sameAs: [`https://github.com/${githubUser}`],
};
---
<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="author" content="Roger Cedeño" />
    <meta name="theme-color" content="#070b14" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${canonical}me/1757515565808.jpeg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${canonical}me/1757515565808.jpeg`} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>

    <header class="header">
      <nav class="container nav" aria-label="Navegación principal">
        <a class="brand" href="#inicio" aria-label="Ir al inicio">
          <span class="monogram" aria-hidden="true">RC</span>
          <span class="brand-copy"><strong>Roger Cedeño</strong><span>Full Stack Software Developer</span></span>
        </a>
        <div class="nav-links">
          <a href="#sobre-mi">Sobre mí</a>
          <a href="#github">GitHub</a>
          <a href="#experiencia">Experiencia</a>
          <a href="#proyectos">Proyectos</a>
        </div>
        <a class="nav-cta" href="mailto:rogercedeno96@gmail.com">Contactar</a>
      </nav>
    </header>

    <main id="contenido">
      <section id="inicio" class="hero">
        <div class="container hero-shell">
          <div class="portrait-column">
            <div class="portrait-frame">
              <img class="profile-image" src="/me/1757515565808.jpeg" alt="Retrato profesional de Roger Cedeño" width="800" height="1000" loading="eager" decoding="async" fetchpriority="high" />
            </div>
          </div>
          <div class="hero-copy">
            <div class="eyebrow"><span class="dot"></span>Desarrollador full stack</div>
            <h1>Construyo soluciones digitales que <span class="gradient-text">generan valor.</span></h1>
            <p class="lead">Desarrollo aplicaciones modernas, seguras y mantenibles con React, TypeScript, .NET y servicios cloud.</p>
            <div class="actions">
              <a class="button button-primary" href="#proyectos">Ver mi trabajo</a>
              <a class="button button-secondary" href={`https://github.com/${githubUser}`} target="_blank" rel="noreferrer">Ver GitHub</a>
            </div>
            <div class="stack" aria-label="Tecnologías principales">{technologies.map((technology) => <span class="chip">{technology}</span>)}</div>
          </div>
        </div>

        <div class="container hero-stats" aria-label="Resumen profesional">
          <div class="hero-stat"><span class="stat-icon">&lt;/&gt;</span><strong>5+</strong><small>Años de experiencia</small></div>
          <div class="hero-stat"><span class="stat-icon">▣</span><strong>{repositoryCount}</strong><small>Repositorios públicos</small></div>
          <div class="hero-stat"><span class="stat-icon">↗</span><strong>{languages.length || 6}+</strong><small>Tecnologías activas</small></div>
          <div class="hero-stat"><span class="stat-icon">✦</span><strong>Full stack</strong><small>Web, móvil y APIs</small></div>
        </div>
      </section>

      <section id="github" class="section github-section">
        <div class="container">
          <div class="section-heading section-heading-row">
            <div><span class="section-kicker">Actividad profesional</span><h2>Actualmente construyendo.</h2><p>Proyectos públicos ordenados por actividad reciente. Los datos se actualizan automáticamente durante cada despliegue.</p></div>
            <a class="text-link" href={`https://github.com/${githubUser}`} target="_blank" rel="noreferrer">Perfil de GitHub →</a>
          </div>
          <div class="activity-grid">
            {activeProjects.map((project, index) => (
              <a class="activity-card" href={project.url} target="_blank" rel="noreferrer">
                <div class="activity-status"><span class:list={['activity-dot', index === 0 && 'activity-dot-active']}></span><span>{index === 0 ? 'Actividad reciente' : 'Proyecto activo'}</span></div>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <div class="activity-footer"><span>{project.language}</span><span>{relativeDate(project.updatedAt)}</span></div>
              </a>
            ))}
          </div>
          <div class="github-summary">
            <div><span>Fuente</span><strong>{githubAvailable ? 'GitHub API' : 'Contenido local de respaldo'}</strong></div>
            <div><span>Repositorios visibles</span><strong>{repositoryCount}</strong></div>
            <div><span>Lenguajes recientes</span><strong>{languages.slice(0, 3).join(' · ') || 'React · .NET · Astro'}</strong></div>
          </div>
        </div>
      </section>

      <section id="sobre-mi" class="section">
        <div class="container">
          <div class="section-heading"><span class="section-kicker">Sobre mí</span><h2>Ingeniería con visión de producto.</h2><p>Combino frontend, backend, experiencia de usuario e infraestructura para construir soluciones mantenibles y preparadas para producción.</p></div>
          <div class="stats">
            <div class="stat"><strong>Full stack</strong><span>Frontend, backend y cloud</span></div>
            <div class="stat"><strong>Mobile-first</strong><span>Experiencias rápidas y adaptables</span></div>
            <div class="stat"><strong>Clean code</strong><span>Arquitectura y mantenibilidad</span></div>
            <div class="stat"><strong>DevOps</strong><span>CI, Docker, Azure y Vercel</span></div>
          </div>
        </div>
      </section>

      <section id="experiencia" class="section">
        <div class="container">
          <div class="section-heading"><span class="section-kicker">Experiencia</span><h2>Soluciones para operaciones reales.</h2><p>Experiencia construyendo aplicaciones empresariales, flujos operativos, integraciones y plataformas multiplataforma.</p></div>
          <div class="timeline">
            <article><h3>Desarrollo full stack</h3><div class="meta">React · TypeScript · .NET 8 · SQL Server</div><p>Implementación de módulos empresariales, permisos, formularios, reportes, APIs y reglas de negocio complejas.</p></article>
            <article><h3>Aplicaciones móviles y PWA</h3><div class="meta">React Native · Flutter · Cordova · Web APIs</div><p>Soporte y evolución de aplicaciones móviles, acceso a capacidades del dispositivo y experiencias instalables.</p></article>
            <article><h3>Infraestructura y despliegue</h3><div class="meta">Azure · Docker · GitHub Actions · Vercel</div><p>Automatización de calidad, despliegues reproducibles y resolución de incidencias entre desarrollo y producción.</p></article>
          </div>
        </div>
      </section>

      <section id="proyectos" class="section">
        <div class="container">
          <div class="section-heading"><span class="section-kicker">Proyectos</span><h2>Repositorios destacados.</h2><p>Proyectos públicos y casos relevantes presentados con información técnica real y enlaces verificables.</p></div>
          <div class="cards">
            {projects.map((project) => (
              <article class="card repo-card">
                <div class="repo-card-head"><span class="repo-language">{project.language}</span><span class="repo-source">{project.source === 'github' ? 'GitHub' : 'Destacado'}</span></div>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <div class="card-tags">{project.tags.map((tag) => <span class="chip">{tag}</span>)}</div>
                <div class="repo-meta"><span>★ {project.stars}</span><span>⑂ {project.forks}</span><span>{relativeDate(project.updatedAt)}</span></div>
                <div class="repo-actions"><a href={project.url} target="_blank" rel="noreferrer">Código →</a>{project.demoUrl && <a href={project.demoUrl} target="_blank" rel="noreferrer">Demo →</a>}</div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="contacto" class="section">
        <div class="container contact-box"><div><h2>Construyamos algo sólido.</h2><p>Disponible para oportunidades, colaboración técnica y desarrollo de productos digitales.</p></div><a class="button button-primary" href="mailto:rogercedeno96@gmail.com">Enviar correo</a></div>
      </section>
    </main>

    <nav class="mobile-nav" aria-label="Navegación móvil">
      <a href="#inicio"><span>⌂</span>Inicio</a>
      <a href="#sobre-mi"><span>○</span>Sobre mí</a>
      <a href="#github"><span>⌘</span>GitHub</a>
      <a href="#proyectos"><span>□</span>Proyectos</a>
      <a href="#contacto"><span>✉</span>Contacto</a>
    </nav>

    <footer class="footer"><div class="container footer-row"><span>© {year} Roger Cedeño</span><span>Construido con Astro, TypeScript y GitHub API</span></div></footer>
    <script is:inline>if ('serviceWorker' in navigator) window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js').catch(() => {}));</script>
  </body>
</html>
